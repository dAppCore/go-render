go 1.26.2

// Workspace mode for development: pulls fresh code from external/ submodules.
//
// Devs:   git clone --recursive   ->   go.work picks up local sources.
// CI:     GOWORK=off               ->   go.mod tags drive resolution.

use (
	./go
	./external/go
	./external/go-i18n/go
	./external/go-inference
	./external/go-io
	./external/go-log
	./external/go-process
)
